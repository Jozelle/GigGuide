<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GigGuide.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GigGuide.MAUI"
    xmlns:views="clr-namespace:GigGuide.MAUI.Views"
    Title="GigGuide.MAUI"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Concerts" Icon="ticket_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:ConcertListPage}" Route="MainPage" />
        </Tab>
        <Tab Title="Account" Icon="account_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:CustomerPage}" Route="MainPage" />
        </Tab>
    </TabBar>

</Shell>
