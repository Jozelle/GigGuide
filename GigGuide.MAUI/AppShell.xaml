<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GigGuide.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GigGuide.MAUI"
    xmlns:views="clr-namespace:GigGuide.MAUI.Views"
    Title="GigGuide.MAUI"
    Shell.FlyoutBehavior="Disabled">


    <ShellContent
        Title="Loading"
        ContentTemplate="{DataTemplate views:LoadingPage}"
        Route="LoadingPage"
        Shell.FlyoutBehavior="Disabled"
        Shell.FlyoutItemIsVisible="False" />

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage"
        Shell.FlyoutBehavior="Disabled"
        Shell.FlyoutItemIsVisible="False" />

    <TabBar x:Name="main" Route="Main">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate views:MainPage}"
            Icon="home_icon.svg"
            Route="MainPage" />
        <ShellContent
            Title="Concerts"
            ContentTemplate="{DataTemplate views:ConcertListPage}"
            Icon="ticket_icon.svg"
            Route="ConcertListPage" />
        <ShellContent
            Title="Account"
            ContentTemplate="{DataTemplate views:CustomerPage}"
            Icon="account_icon.svg"
            Route="CustomerPage" />
    </TabBar>

</Shell>
