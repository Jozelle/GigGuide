<ContentPage
    x:Class="GigGuide.MAUI.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Login"
    Shell.NavBarIsVisible="False"
    >

    <ContentPage.Behaviors>
        <behaviors:EventToCommandBehavior Command="{Binding AppearingCommand}" EventName="Appearing" />
    </ContentPage.Behaviors>
    
    <VerticalStackLayout Padding="20" Spacing="10">
        <Label Text="Login" FontSize="24" HorizontalOptions="Center" />

        <!-- Email Entry -->
        <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" />
        <Label Text="{Binding Errors[Email]}" TextColor="Red" 
          />

        <!-- Password Entry -->
        <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" />
        <Label Text="{Binding Errors[Password]}" TextColor="Red" 
          />

        <!-- Login Button -->
        <Button Text="Login" Command="{Binding LoginCommand}" />
        <Label Text="{Binding ErrorMessage}" TextColor="Red" 
            />
    </VerticalStackLayout>


</ContentPage>
