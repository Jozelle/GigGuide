<ContentPage
    x:Class="GigGuide.MAUI.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Login"
    BackgroundImageSource="Images/background.jpg">

    <ContentPage.Behaviors>
        <behaviors:EventToCommandBehavior Command="{Binding AppearingCommand}" EventName="Appearing" />
    </ContentPage.Behaviors>

    <VerticalStackLayout Padding="20,150" Spacing="10">
        <Border
            Margin="0,5"
            Padding="5"
            BackgroundColor="FloralWhite"
            StrokeShape="RoundRectangle 10">
            <VerticalStackLayout>
                <Label
                    FontSize="24"
                    HorizontalOptions="Center"
                    Text="Login" />

                <!--  Email Entry  -->
                <Entry
                    Keyboard="Email"
                    Placeholder="Email"
                    Text="{Binding Email}" />
                <Label Text="{Binding Errors[Email]}" TextColor="Red" />

                <!--  Password Entry  -->
                <Entry
                    IsPassword="True"
                    Placeholder="Password"
                    Text="{Binding Password}" />
                <Label Text="{Binding Errors[Password]}" TextColor="Red" />

                <!--  Login Button  -->
                <Button Command="{Binding LoginCommand}" Text="Login" />
                <Label Text="{Binding ErrorMessage}" TextColor="Red" />
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>


</ContentPage>
