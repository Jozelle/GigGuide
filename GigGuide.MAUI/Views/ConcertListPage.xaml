<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GigGuide.MAUI.Views.ConcertListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:controls="clr-namespace:GigGuide.MAUI.Controls"
    xmlns:models="clr-namespace:GigGuide.MAUI.Models"
    Title="Concerts"
    BackgroundImageSource="Images/background.jpg">
    <ContentPage.Behaviors>
        <behaviors:EventToCommandBehavior Command="{Binding AppearingCommand}" EventName="Appearing" />
    </ContentPage.Behaviors>
    <ContentPage.Content>

        <ScrollView>
            <StackLayout Margin="5" Padding="10">
                <Label Text="Concerts" FontSize="Large" FontAttributes="Bold" />
                <CollectionView
                    ItemsSource="{Binding Concerts}"
                    SelectedItem="{Binding SelectedConcert, Mode=TwoWay}"
                    SelectionMode="Single">
                    <CollectionView.Behaviors>
                        <behaviors:EventToCommandBehavior Command="{Binding NavigateToConcertCommand}" EventName="SelectionChanged" />
                    </CollectionView.Behaviors>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Concert">
                            <Border
                                Margin="0,5"
                                Padding="5"
                                BackgroundColor="FloralWhite"
                                StrokeShape="RoundRectangle 10">
                                <StackLayout Padding="10">
                                    <Label FontSize="Title" Text="{Binding ConcertArtist}" />
                                    <Label FontSize="Subtitle" Text="{Binding ConcertTitle}" />
                                </StackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </StackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>