<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GigGuide.MAUI.Views.CustomerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:models="clr-namespace:GigGuide.MAUI.Models"
    Title="CustomerPage">
    <ContentPage.Behaviors>
        <behaviors:EventToCommandBehavior Command="{Binding AppearingCommand}" EventName="Appearing" />
    </ContentPage.Behaviors>
    <ScrollView Margin="10">
        <VerticalStackLayout>
            <!--  Welcome Message  -->
            <Label
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="Center"
                Text="{Binding WelcomeMessage}" />
            <!--  User Settings Section  -->
            <Label
                Margin="0,20,0,10"
                FontAttributes="Bold"
                FontSize="20"
                Text="User Settings" />

            <Label Text="{Binding CurrentCustomer.CustomerFirstName}" />
            <Label Text="{Binding CurrentCustomer.CustomerLastName}" />

            <!-- Email Update Section -->
            <Label Text="Current Email:" FontAttributes="Bold" FontSize="Small" />
            <Label Text="{Binding CurrentCustomer.CustomerEmail}" x:Name="CurrentEmailLabel" />

            <Button Text="Update Email" Command="{Binding ShowEmailEditCommand}" />

            <StackLayout IsVisible="{Binding IsEmailEditVisible}">
                <Entry Text="{Binding NewEmail}" Placeholder="Enter new email" />
                <Label Text="{Binding EmailError}" TextColor="Red" IsVisible="{Binding IsErrorVisible}" />
                <Button Text="Save Email" Command="{Binding UpdateEmailCommand}" />
                <Button Text="Cancel" Command="{Binding CancelEmailEditCommand}" />
            </StackLayout>

            <Label Text="{Binding CurrentCustomer.CustomerPhone}" />

            <!-- Password Change Section -->
            <Label Text="Change Password" FontAttributes="Bold" FontSize="Small" />
            <Button Text="Change Password" Command="{Binding ShowPasswordEditCommand}" />

            <StackLayout IsVisible="{Binding IsPasswordEditVisible}">
                <Entry Text="{Binding NewPassword}" Placeholder="Enter new password" IsPassword="True"/>
                <Entry Text="{Binding ConfirmPassword}" Placeholder="Confirm new password" IsPassword="True"/>
                <Label Text="{Binding PasswordError}" TextColor="Red" IsVisible="{Binding IsPasswordErrorVisible}" />
                <Button Text="Save Password" Command="{Binding ChangePasswordCommand}" />
                <Button Text="Cancel" Command="{Binding CancelPasswordEditCommand}" />
            </StackLayout>
            <!--  My Bookings Section  -->
            <Label
                Margin="0,20,0,10"
                FontAttributes="Bold"
                FontSize="20"
                Text="My Bookings" />

            <CollectionView
                ItemsSource="{Binding MyBookings}"
                SelectedItem="{Binding SelectedBooking, Mode=TwoWay}"
                SelectionMode="Single">
                <CollectionView.Behaviors>
                    <behaviors:EventToCommandBehavior Command="{Binding NavigateToBookingCommand}" EventName="SelectionChanged" />
                </CollectionView.Behaviors>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Booking">
                        <Border
                            Margin="0,5"
                            Padding="5"
                            StrokeShape="RoundRectangle 10">
                            <StackLayout>
                                <Label FontSize="Medium" Text="{Binding Performance.PerformanceConcert.ConcertArtist}" />
                                <Label FontSize="Small" Text="{Binding Performance.PerformanceConcert.ConcertTitle}" />
                                <Label FontSize="Small" Text="{Binding Performance.PerformanceLocation}" />
                                <Label FontSize="Small" Text="{Binding BookingQuantity, StringFormat='{}{0} tickets'}" />
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>